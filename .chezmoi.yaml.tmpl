{{- $email := promptStringOnce . "email" "What is your email address" -}}
{{- $profileChoices := list "personal" "work" -}}
{{- $profile := promptChoiceOnce . "profiles" "Which profile should be used for this machine" $profileChoices -}}
{{- $opAccountId := promptStringOnce . "opAccountId" "Which 1Password account ID should be used for dotfiles" }}
{{- $omarchy := not (not (stat (joinPath .chezmoi.homeDir ".local/share/omarchy"))) }}
template:
  options:
  - "missingkey=invalid"
git:
  autoCommit: true
  autoPush: true
hooks:
  read-source-state:
    pre:
      command: "{{ .chezmoi.sourceDir }}/.install-password-manager.sh"
data:
  email: {{ $email | quote }}
  profile: {{ $profile | quote }}
  zshrc_snippet: ""
  homebrew:
    brews: []
    casks: []
    taps: []
    mas: []
  pacman:
    packages: []
  aur:
    packages: []
  bashrc_snippet: ""
  omarchy: {{ $omarchy }}
  onepassword:
    account: {{ $opAccountId | quote }}
